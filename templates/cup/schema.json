{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["units", "cup", "output"],
  "properties": {
    "units": { "type": "string", "const": "mm" },
    "material_hint": { "type": "string" },
    "cup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outer_diameter", "height", "wall_thickness", "bottom_thickness"],
      "properties": {
        "outer_diameter": { "type": "number", "exclusiveMinimum": 0.0 },
        "height": { "type": "number", "exclusiveMinimum": 0.0 },
        "wall_thickness": { "type": "number", "exclusiveMinimum": 0.0 },
        "bottom_thickness": { "type": "number", "exclusiveMinimum": 0.0 },
        "handle_width": { "type": "number", "minimum": 0.0 },
        "handle_height": { "type": "number", "minimum": 0.0 },
        "handle_thickness": { "type": "number", "minimum": 0.0 }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "stl"],
      "properties": {
        "step": { "type": "boolean" },
        "stl": { "type": "boolean" },
        "tolerance": { "type": "number", "exclusiveMinimum": 0.0 }
      }
    }
  }
}
