{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["units", "enclosure", "output"],
  "properties": {
    "units": { "type": "string", "const": "mm" },
    "material_hint": { "type": "string" },
    "enclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["size", "wall_thickness", "lid_thickness", "screws"],
      "properties": {
        "size": {
          "type": "object",
          "additionalProperties": false,
          "required": ["length", "width", "height"],
          "properties": {
            "length": { "type": "number", "exclusiveMinimum": 0.0 },
            "width": { "type": "number", "exclusiveMinimum": 0.0 },
            "height": { "type": "number", "exclusiveMinimum": 0.0 }
          }
        },
        "wall_thickness": { "type": "number", "exclusiveMinimum": 0.0 },
        "lid_thickness": { "type": "number", "exclusiveMinimum": 0.0 },
        "corner_radius": { "type": "number", "minimum": 0.0 },
        "screws": {
          "type": "object",
          "additionalProperties": false,
          "required": ["count", "hole_diameter", "boss_diameter", "edge_offset"],
          "properties": {
            "count": { "type": "integer", "enum": [0, 2, 4] },
            "hole_diameter": { "type": "number", "exclusiveMinimum": 0.0 },
            "boss_diameter": { "type": "number", "exclusiveMinimum": 0.0 },
            "edge_offset": { "type": "number", "minimum": 0.0 }
          }
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["step", "stl"],
      "properties": {
        "step": { "type": "boolean" },
        "stl": { "type": "boolean" },
        "tolerance": { "type": "number", "exclusiveMinimum": 0.0 }
      }
    }
  }
}
